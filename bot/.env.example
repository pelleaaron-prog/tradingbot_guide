# --- Binance API Keys ---
# Get these from Account -> API Management
# MAKE SURE TO DISABLE WITHDRAWALS!
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_key_here

# --- Telegram Bot ---
# Get this from @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefghijklmnopqrstuvwxyz
# Get this from @userinfobot
TELEGRAM_CHAT_ID=123456789

# --- Trading Parameters ---
SYMBOL=BTC/USDT
TIMEFRAME=1h
TRADE_AMOUNT_USDT=50.0
POSITION_SIZE_PCT=0.20

# --- Risk Management ---
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DAILY_LOSS_PCT=0.10

# --- Strategy ---
EMA_SHORT=20
EMA_LONG=50
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
CANDLE_LIMIT=200

# --- Execution Mode ---
# SET THIS TO false ONLY WHEN YOU ARE READY TO USE REAL MONEY
DRY_RUN=true
LOG_LEVEL=INFO
